{
  "name": "netpilot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "cleanup": "node cleanup-ports.js",
    "dev": "npm run cleanup && concurrently \"npm run dev:backend\" \"npm run wait:backend && npm run dev:frontend\"",
    "wait:backend": "wait-on tcp:127.0.0.1:8003 --interval 500 --timeout 120000",
    "dev:backend:win": "cross-env NODE_ENV=development PYTHONPATH=backend .venv/Scripts/python.exe backend/main.py",
    "dev:backend:linux": "cross-env NODE_ENV=development PYTHONPATH=backend .venv/bin/python backend/main.py",
    "dev:backend": "node -e \"const p=process.platform==='win32'?'.venv/Scripts/python.exe':'.venv/bin/python';require('child_process').execSync('cross-env NODE_ENV=development PYTHONPATH=backend '+p+' backend/main.py',{stdio:'inherit'})\"",
    "dev:frontend": "vite --port 3000 --host 0.0.0.0",
    "start:win": "npm run build && cross-env NODE_ENV=production .venv/Scripts/python.exe backend/main.py",
    "start:linux": "npm run build && cross-env NODE_ENV=production .venv/bin/python backend/main.py",
    "start": "node -e \"const p=process.platform==='win32'?'.venv/Scripts/python.exe':'.venv/bin/python';require('child_process').execSync('cross-env NODE_ENV=production '+p+' backend/main.py',{stdio:'inherit'})\"",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "d3": "^7.9.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "ping": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "ssh2": "^1.17.0",
    "uuid": "^13.0.0",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  }
}
